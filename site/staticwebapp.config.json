{
  "routes": [
    { "route": "/work", "rewrite": "/work/index.html" },
    { "route": "/about", "rewrite": "/about/index.html" },
    { "route": "/contact", "rewrite": "/contact/index.html" },
    { "route": "/assess", "rewrite": "/assess/index.html" }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
